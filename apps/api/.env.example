# App
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/autoclaw

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here

# Meta (WhatsApp + Instagram)
META_APP_ID=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=
META_WHATSAPP_API_VERSION=v18.0

# Encryption (para credenciales de integraciones)
ENCRYPTION_KEY=

# VTEX
VTEX_ACCOUNT_NAME=
VTEX_API_KEY=
VTEX_API_TOKEN=

# Docker
DOCKER_SOCKET=/var/run/docker.sock
OPENCLAW_IMAGE=openclaw/openclaw:latest
TENANTS_DATA_DIR=/opt/autoclaw/tenants

# MercadoPago
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
PLAN_PRO_PRICE_ARS=15000
PLAN_ENTERPRISE_PRICE_ARS=45000
BILLING_SUCCESS_URL=http://localhost:3001/settings

# CORS
CORS_ORIGIN=http://localhost:3001
